# ============================================
# MOVE APP — Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# --- Clerk Auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Database (Postgres via Supabase or Railway) ---
DATABASE_URL="postgresql://user:password@host:5432/move_db?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/move_db?schema=public"

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Price IDs (create in Stripe dashboard)
STRIPE_PRICE_LITE=price_xxxxxxxx
STRIPE_PRICE_STANDARD=price_xxxxxxxx
STRIPE_PRICE_PLUS=price_xxxxxxxx
STRIPE_PRICE_BUSINESS=price_xxxxxxxx

# --- Anthropic (Claude AI) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_PHONE_NUMBER=+81xxxxxxxxxx

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
